{
  "name": "git-playground-watcher",
  "version": "1.0.0",
  "private": true,
  "description": "Tableau de bord visuel et live pour observer plusieurs depots git dans un playground (bac a sable)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js ../playground",
